# Auth.js
# Generate with: npx auth secret
AUTH_SECRET=

# Google OAuth web client
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional: set both variables to show the selected-sheet service-account
# option on /setup. Copy client_email and private_key from the service
# account JSON key. Keep the literal \n characters in the private key.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional outside Vercel when Auth.js cannot infer the application origin.
# AUTH_URL=http://localhost:3000
